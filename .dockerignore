# Dependencies (rebuilt inside Docker)
node_modules

# Next.js build cache
.next

# Local databases (never ship dev data)
*.db
*.db-journal
*.db-wal
*.db-shm
prisma/dev.db

# Environment files (injected at runtime via docker-compose env_file)
.env
.env.*
!.env.production.example

# Dev / editor artefacts
.git
.gitignore
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript incremental build info
*.tsbuildinfo

# Test / coverage
coverage

# Docs (not needed in the image)
README.md
DEPLOY.md
USER_GUIDE.md
